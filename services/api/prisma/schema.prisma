generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Worker {
  id                  String   @id @default(cuid())
  phone               String   @unique
  name                String
  city                String
  pincode             String
  platform            String
  upiHandle           String
  aadhaarLast4        String
  baselineIncomePaise Int
  deviceFingerprint   String?
  status              String   @default("active")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  policies            Policy[]
  payouts             Payout[]
}

model Policy {
  id                 String   @id @default(cuid())
  workerId           String
  weekStart          DateTime
  weekEnd            DateTime
  premiumAmountPaise Int
  riskScore          Float
  status             String   @default("active")
  premiumPaidAt      DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  worker             Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
}

model SensorReading {
  id             String   @id @default(cuid())
  city           String
  pincode        String?
  rainfallMmHr   Float
  heatIndexC     Float
  aqiScore       Float
  cancelRatePct  Float
  platformStatus String
  orderDensity   Float
  source         String
  recordedAt     DateTime @default(now())

  @@index([city, recordedAt])
}

model Payout {
  id                String      @id @default(cuid())
  workerId          String
  triggerType       String
  triggerValue      Float       @default(0)
  payoutAmountPaise Int
  status            String      @default("pending")
  fraudScore        Float       @default(0)
  fraudComponents   Json?
  creditedAt        DateTime?
  createdAt         DateTime    @default(now())
  worker            Worker      @relation(fields: [workerId], references: [id], onDelete: Cascade)
  fraudFlags        FraudFlag[]
}

model FraudFlag {
  id           String   @id @default(cuid())
  workerId     String
  payoutId     String
  type         String   @default("behavioral")
  scoreB       Float    @default(0)
  scoreG       Float    @default(0)
  scoreL       Float    @default(0)
  scoreTotal   Float    @default(0)
  reviewStatus String   @default("pending")
  reviewedAt   DateTime?
  reviewedBy   String?
  createdAt    DateTime @default(now())
  payout       Payout   @relation(fields: [payoutId], references: [id], onDelete: Cascade)

  @@index([reviewStatus, createdAt])
}
